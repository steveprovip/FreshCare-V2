@model FreshCare.Models.ViewModels.QuenMatKhauViewModel
@{ ViewData["Title"] = "Quên mật khẩu"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card card-fc shadow-lg">
            <div class="card-header text-center py-4" style="background: linear-gradient(135deg,#1b4332,#2d6a4f); border-radius:16px 16px 0 0;">
                <div class="mb-2">
                    <i class="fas fa-lock-open fa-3x" style="color:#52b788;"></i>
                </div>
                <h4 class="text-white mb-0 fw-bold">Quên mật khẩu</h4>
                <small class="text-white-50">Bước 1/2 — Xác minh danh tính</small>
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div class="alert alert-danger py-2">
                            <i class="fas fa-exclamation-circle me-2"></i>@error.ErrorMessage
                        </div>
                    }
                }

                <p class="text-muted small mb-4">
                    <i class="fas fa-info-circle me-1 text-primary"></i>
                    Nhập tên đăng nhập cùng với Email <strong>và</strong> Số điện thoại 
                    đã đăng ký để xác minh tài khoản của bạn.
                </p>

                <form asp-action="QuenMatKhau" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-user me-1 text-secondary"></i>Tên đăng nhập <span class="text-danger">*</span>
                        </label>
                        <input asp-for="TenDangNhap" class="form-control" placeholder="Nhập tên đăng nhập" required />
                        <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-envelope me-1 text-secondary"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="example@email.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-phone me-1 text-secondary"></i>Số điện thoại <span class="text-danger">*</span>
                        </label>
                        <input asp-for="SoDienThoai" type="tel" class="form-control" placeholder="0912 345 678" required />
                        <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-fc-primary w-100 py-2">
                        <i class="fas fa-shield-alt me-2"></i>Xác minh tài khoản
                    </button>
                </form>

                <hr class="my-3">
                <div class="text-center">
                    <a href="/TaiKhoan/DangNhap" class="text-decoration-none text-secondary small">
                        <i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
