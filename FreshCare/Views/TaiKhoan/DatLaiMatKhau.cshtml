@model FreshCare.Models.ViewModels.DatLaiMatKhauViewModel
@{ ViewData["Title"] = "Đặt lại mật khẩu"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card card-fc shadow-lg">
            <div class="card-header text-center py-4" style="background: linear-gradient(135deg,#1b4332,#2d6a4f); border-radius:16px 16px 0 0;">
                <div class="mb-2">
                    <i class="fas fa-key fa-3x" style="color:#52b788;"></i>
                </div>
                <h4 class="text-white mb-0 fw-bold">Đặt mật khẩu mới</h4>
                <small class="text-white-50">Bước 2/2 — Tài khoản: <strong>@Model.TenDangNhap</strong></small>
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div class="alert alert-danger py-2">
                            <i class="fas fa-exclamation-circle me-2"></i>@error.ErrorMessage
                        </div>
                    }
                }

                <div class="alert alert-success py-2 mb-4">
                    <i class="fas fa-check-circle me-2"></i>
                    Xác minh thành công! Hãy nhập mật khẩu mới cho tài khoản <strong>@Model.TenDangNhap</strong>.
                </div>

                <form asp-action="DatLaiMatKhau" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="MaNV" />
                    <input type="hidden" asp-for="TenDangNhap" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-lock me-1 text-secondary"></i>Mật khẩu mới
                        </label>
                        <div class="input-group">
                            <input asp-for="MatKhauMoi" type="password" id="matKhauMoi" class="form-control" 
                                   placeholder="Tối thiểu 6 ký tự" required />
                            <button class="btn btn-outline-secondary" type="button" id="togglePwd1">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="MatKhauMoi" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-lock me-1 text-secondary"></i>Xác nhận mật khẩu mới
                        </label>
                        <div class="input-group">
                            <input asp-for="XacNhanMatKhauMoi" type="password" id="xacNhanMatKhauMoi" class="form-control" 
                                   placeholder="Nhập lại mật khẩu mới" required />
                            <button class="btn btn-outline-secondary" type="button" id="togglePwd2">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="XacNhanMatKhauMoi" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-fc-primary w-100 py-2">
                        <i class="fas fa-save me-2"></i>Lưu mật khẩu mới
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePassword(btnId, inputId) {
        document.getElementById(btnId).addEventListener('click', function () {
            var input = document.getElementById(inputId);
            var icon = this.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    }
    togglePassword('togglePwd1', 'matKhauMoi');
    togglePassword('togglePwd2', 'xacNhanMatKhauMoi');
</script>
}
