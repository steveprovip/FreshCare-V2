@model FreshCare.Models.ViewModels.ChiTietPhieuXuatViewModel
@{
    ViewData["Title"] = "Chi Tiết Phiếu Xuất: " + Model.MaPhieuXuat;
}

@section Styles {
<style>
    /* Phần CSS riêng cho giao diện in ấn (Print) */
    @@media print {
        body * {
            visibility: hidden;
        }
        #printable-invoice, #printable-invoice * {
            visibility: visible;
        }
        #printable-invoice {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }
        .btn, .navbar-freshcare, .no-print {
            display: none !important;
        }
        .table-fc thead th {
            background-color: #f8f9fa !important;
            color: #000 !important;
            border-bottom: 2px solid #2d6a4f !important;
        }
        /* Fix màu in nếu trình duyệt cấu hình ẩn background */
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    }

    .invoice-card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        padding: 30px;
        background: #fff;
    }
    
    .invoice-header {
        border-bottom: 2px solid #2d6a4f;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }
</style>
}

<div class="row mb-3 no-print">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <a href="/XuatKho/LichSu" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Quay lại
        </a>
        <button onclick="window.print()" class="btn btn-fc-primary">
            <i class="fas fa-print me-1"></i> In Hóa Đơn
        </button>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="invoice-card" id="printable-invoice">
            <!-- Header Hóa Đơn -->
            <div class="invoice-header d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-0" style="color: #2d6a4f; font-weight: 700;">
                        <i class="fas fa-leaf me-2"></i> FRESHCARE
                    </h3>
                    <p class="text-muted mb-0 small">Thực phẩm Tươi sạch & Hữu cơ</p>
                </div>
                <div class="text-end">
                    <h5 class="fw-bold mb-1">
                        PHIẾU @Model.LoaiPhieu.ToUpper()
                    </h5>
                    <p class="mb-0 text-muted">Số phiếu: <strong>HD-@Model.MaPhieuXuat.ToString("D4")</strong></p>
                </div>
            </div>

            <!-- Thông tin phiếu -->
            <div class="row mb-4 pt-2">
                <div class="col-sm-6">
                    <h6 class="fw-bold">Thông tin cửa hàng:</h6>
                    <p class="mb-1 small">Chi nhánh: Cơ sở chính</p>
                    <p class="mb-1 small">Nhân viên lập: <strong>@Model.TenNhanVien</strong></p>
                </div>
                <div class="col-sm-6 text-sm-end">
                    <p class="mb-1 small">Thời gian: <strong>@Model.NgayXuat.ToString("dd/MM/yyyy HH:mm")</strong></p>
                    <p class="mb-1 small">Loại chứng từ: <span class="badge @(Model.LoaiPhieu == "Hủy Hàng" ? "bg-secondary" : "bg-success")">@Model.LoaiPhieu</span></p>
                </div>
            </div>

            <!-- Chi tiết hàng hóa -->
            <table class="table table-fc table-bordered mb-4">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lô</th>
                        <th class="text-end">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model.DanhSachChiTiet)
                    {
                        <tr>
                            <td class="text-center">@(stt++)</td>
                            <td><strong>@item.TenSanPham</strong></td>
                            <td class="text-center">LO-@item.MaLo.ToString("D4")</td>
                            <td class="text-end">@item.SoLuong.ToString("G29")</td>
                            <td class="text-end">@item.DonGia.ToString("N0")</td>
                            <td class="text-end fw-semibold">@( (item.SoLuong * item.DonGia).ToString("N0") )</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Tổng kết hóa đơn -->
            <div class="row">
                <div class="col-7">
                    <p class="small text-muted fst-italic">Cảm ơn quý khách đã mua sắm tại FreshCare!</p>
                </div>
                <div class="col-5 text-end">
                    <div class="fs-5 fw-bold" style="color: #e63946;">
                        Tổng cộng: <span>@Model.TongTien.ToString("N0") đ</span>
                    </div>
                </div>
            </div>
            
            @if(Model.LoaiPhieu == "Hủy Hàng")
            {
                <div class="mt-4 pt-3 border-top text-center text-muted small">
                    <p class="mb-0 text-danger"><i class="fas fa-exclamation-triangle me-1"></i> Đây là chứng từ xuất hủy nội bộ, ghi nhận hao hụt vào hệ thống.</p>
                </div>
            }

        </div>
    </div>
</div>