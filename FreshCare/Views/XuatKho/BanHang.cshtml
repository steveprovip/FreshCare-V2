@model XuatKhoViewModel
@{ ViewData["Title"] = "Xuất kho - Bán hàng"; }

<h4 class="section-title"><i class="fas fa-upload me-2"></i>Xuất Kho — Bán Hàng (FEFO)</h4>

<div class="row">
    <div class="col-md-8">
        <div class="card card-fc">
            <div class="card-body">
                <form asp-action="ThanhToan" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Quét mã vạch nhanh -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <label class="form-label fw-semibold"><i class="fas fa-barcode me-1 text-primary"></i>Quét mã vạch (tùy chọn)</label>
                        <div class="input-group">
                            <input type="text" id="txtMaVachXuat" class="form-control" placeholder="Quét hoặc nhập mã vạch sản phẩm..." />
                            <button type="button" class="btn btn-outline-primary" id="btnQuetMaXuat"><i class="fas fa-search me-1"></i>Tìm</button>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold"><i class="fas fa-box me-1"></i>Sản phẩm <span class="text-danger">*</span></label>
                            <select asp-for="MaSP" class="form-select" id="ddlSanPhamXuat" required>
                                <option value="">-- Chọn sản phẩm --</option>
                                @foreach (var sp in Model.DanhSachSanPham)
                                {
                                    <option value="@sp.MaSP" data-gianhap="@sp.GiaNhap" data-giaban="@sp.GiaBan" data-dvt="@sp.DonViTinh">
                                        @sp.TenSP (@sp.DonViTinh) - Giá bán: @sp.GiaBan.ToString("N0")đ
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold"><i class="fas fa-weight-hanging me-1"></i>Số lượng <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="SoLuong" type="number" step="0.01" min="0.01" class="form-control" id="txtSoLuongXuat" required />
                                <span class="input-group-text" id="lblDVTXuat">---</span>
                            </div>
                            <small class="text-muted">Tồn kho: <span id="lblTonKho" class="fw-bold text-success">--</span></small>
                        </div>

                        <!-- Hiển thị giá nhập và giá bán -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-tag me-1 text-danger"></i>Giá nhập</label>
                            <div class="input-group">
                                <input type="text" id="txtGiaNhapXuat" class="form-control" readonly disabled />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-tag me-1 text-success"></i>Giá bán</label>
                            <div class="input-group">
                                <input type="text" id="txtGiaBanXuat" class="form-control" readonly disabled />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold"><i class="fas fa-sticky-note me-1"></i>Ghi chú</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Ghi chú hóa đơn (không bắt buộc)"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-fc-primary btn-lg">
                            <i class="fas fa-cash-register me-2"></i>Thanh Toán
                        </button>
                        <a href="/Home/Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-fc bg-light">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-cogs me-2 text-primary"></i>Thuật toán FEFO</h6>
            </div>
            <div class="card-body">
                <p class="small mb-2"><strong>First Expired, First Out</strong></p>
                <ol class="small mb-0">
                    <li>Tìm các lô hàng còn tồn (chưa quá hạn)</li>
                    <li>Sắp xếp theo HSD tăng dần</li>
                    <li>Trừ từ lô sắp hết hạn nhất</li>
                    <li>Nếu không đủ → trừ lô kế tiếp</li>
                    <li>Ghi nhận hóa đơn chi tiết</li>
                </ol>
                <hr/>
                <p class="small text-muted mb-0">
                    <i class="fas fa-shield-alt text-success me-1"></i>
                    Hệ thống tự động chặn xuất hàng quá hạn và chặn xuất vượt tồn kho.
                </p>
            </div>
        </div>

        <!-- Thông tin sản phẩm đã chọn -->
        <div class="card card-fc mt-3 d-none" id="cardInfoXuat">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-box-open me-2"></i>Sản phẩm đã chọn</h6>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong id="infoTenSPXuat">---</strong></p>
                <p class="mb-1 text-muted">Đơn vị: <span id="infoDVTXuat">---</span></p>
                <p class="mb-1">Giá nhập: <span class="fw-bold text-danger" id="infoGiaNhapXuat">---</span></p>
                <p class="mb-0">Giá bán: <span class="fw-bold text-success" id="infoGiaBanXuat">---</span></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Luật #14: AJAX lấy tồn kho real-time
    $('#ddlSanPhamXuat').on('change', function () {
        var maSP = $(this).val();
        var selected = $(this).find('option:selected');

        if (!maSP) {
            $('#lblDVTXuat').text('---');
            $('#lblTonKho').text('--');
            $('#txtGiaNhapXuat').val('');
            $('#txtGiaBanXuat').val('');
            $('#cardInfoXuat').addClass('d-none');
            return;
        }

        var dvt = selected.data('dvt');
        var giaNhap = selected.data('gianhap');
        var giaBan = selected.data('giaban');
        var tenSP = selected.text().split('(')[0].trim();

        // Hiển thị giá nhập và giá bán
        $('#txtGiaNhapXuat').val(Number(giaNhap).toLocaleString('vi-VN'));
        $('#txtGiaBanXuat').val(Number(giaBan).toLocaleString('vi-VN'));

        // Hiển thị info card
        $('#infoTenSPXuat').text(tenSP);
        $('#infoDVTXuat').text(dvt);
        $('#infoGiaNhapXuat').text(Number(giaNhap).toLocaleString('vi-VN') + 'đ');
        $('#infoGiaBanXuat').text(Number(giaBan).toLocaleString('vi-VN') + 'đ');
        $('#cardInfoXuat').removeClass('d-none');

        $.get('/XuatKho/LayTonKho', { maSP: maSP }, function (data) {
            if (data.success) {
                $('#lblDVTXuat').text(data.donViTinh);
                $('#lblTonKho').text(data.tongTon + ' ' + data.donViTinh);
                // Luật #10: ràng buộc đơn vị (Chỉ Kg cho phép thập phân)
                if (data.donViTinh === 'Kg') {
                    $('#txtSoLuongXuat').attr('step', '0.01').attr('min', '0.01');
                } else {
                    $('#txtSoLuongXuat').attr('step', '1').attr('min', '1');
                    var val = $('#txtSoLuongXuat').val();
                    if (val && val % 1 !== 0) {
                        $('#txtSoLuongXuat').val(Math.floor(val));
                    }
                }
            }
        });
    });

    // Quét mã vạch xuất kho
    $('#btnQuetMaXuat').on('click', function () {
        var maVach = $('#txtMaVachXuat').val().trim();
        if (!maVach) return;

        $.get('/SanPham/TimTheoMaVach', { maVach: maVach }, function (data) {
            if (data.success) {
                $('#ddlSanPhamXuat').val(data.maSP).trigger('change');
                $('#txtMaVachXuat').val('').addClass('is-valid');
                setTimeout(function() { $('#txtMaVachXuat').removeClass('is-valid'); }, 2000);
            } else {
                $('#txtMaVachXuat').addClass('is-invalid');
                setTimeout(function() { $('#txtMaVachXuat').removeClass('is-invalid'); }, 2000);
            }
        });
    });

    $('#txtMaVachXuat').on('keypress', function (e) {
        if (e.which === 13) {
            e.preventDefault();
            $('#btnQuetMaXuat').click();
        }
    });

    // Validate form trước khi submit
    $('form').on('submit', function (e) {
        var maSP = $('#ddlSanPhamXuat').val();
        if (!maSP) {
            e.preventDefault();
            alert('Vui lòng chọn sản phẩm!');
            return false;
        }

        var sl = parseFloat($('#txtSoLuongXuat').val());
        if (!sl || sl <= 0) {
            e.preventDefault();
            alert('Số lượng phải lớn hơn 0!');
            return false;
        }

        var dvt = $('#lblDVTXuat').text();
        if (dvt !== 'Kg' && dvt !== '---' && sl % 1 !== 0) {
            e.preventDefault();
            alert('Đơn vị "' + dvt + '" chỉ cho phép nhập số nguyên!');
            return false;
        }
    });
</script>
}

