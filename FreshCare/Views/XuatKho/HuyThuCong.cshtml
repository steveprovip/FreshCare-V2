@model XuatKhoViewModel
@{ ViewData["Title"] = "Xuất kho - Hủy hàng thủ công"; }

<h4 class="section-title"><i class="fas fa-trash-alt me-2 text-danger"></i>Xuất Kho — Hủy Hàng Thủ Công (FEFO)</h4>

<div class="row">
    <div class="col-md-12">
        <div class="card card-fc border-start border-danger border-4">
             <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Phiếu Xuất Hủy</h5>
            </div>
            <div class="card-body">
                <form asp-action="XacNhanHuyThuCong" method="post" id="formHuyHang">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold mb-0"><i class="fas fa-list me-1"></i>Danh sách mặt hàng xuất hủy</h6>
                            <button type="button" class="btn btn-sm btn-outline-danger" id="btnThemDong">
                                <i class="fas fa-plus me-1"></i>Thêm mặt hàng
                            </button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-bordered" id="tblXuatHang">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:30%">Sản phẩm <span class="text-danger">*</span></th>
                                        <th style="width:12%">Số lượng hủy <span class="text-danger">*</span></th>
                                        <th style="width:18%">Theo ĐVT / Hệ số</th>
                                        <th style="width:15%">Tồn kho kho</th>
                                        <th style="width:15%">Thất thoát ước tính</th>
                                        <th style="width:5%">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyXuatHang">
                                    <tr class="xuat-row" data-index="0">
                                        <td>
                                            <select name="DanhSachXuat[0].MaSP" class="form-select select2-row" required>
                                                <option value="">-- Chọn sản phẩm --</option>
                                                @foreach (var sp in Model.DanhSachSanPham)
                                                {
                                                    <option value="@sp.MaSP">
                                                        @sp.TenSP (@sp.DonViTinh)
                                                    </option>
                                                }
                                            </select>
                                        </td>
                                        <td><input name="DanhSachXuat[0].SoLuong" type="number" step="0.01" min="0.01" class="form-control txt-soluong" required /></td>
                                        <td>
                                            <div class="input-group input-group-sm mb-1">
                                                <input name="DanhSachXuat[0].DonViQuyDoi" class="form-control" placeholder="ĐVT..." title="Đơn vị xuất (vd: Vỉ, Thùng)" />
                                                <span class="input-group-text bg-light">x</span>
                                                <input name="DanhSachXuat[0].HeSoQuyDoi" type="number" step="0.01" min="1" class="form-control txt-heso" value="1" title="Hệ số về ĐVT gốc" />
                                            </div>
                                            <small class="text-muted" style="font-size:0.7rem;">Gốc: <span class="badge bg-info lbl-dvt">---</span></small>
                                        </td>
                                        <td><strong class="text-success lbl-tonkho">---</strong></td>
                                        <td><strong class="text-danger lbl-thanhtien">---</strong></td>
                                        <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger btn-xoa-dong" title="Xóa dòng"><i class="fas fa-trash"></i></button></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Ghi chú & Lệnh -->
                    <div class="row">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold"><i class="fas fa-sticky-note me-1"></i>Nguyên nhân / Ghi chú</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Ví dụ: Rơi vỡ, mốc hỏng, chuột cắn..."></textarea>
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-2">
                            <a href="/Home/Index" class="btn btn-outline-secondary btn-lg flex-fill">
                                <i class="fas fa-arrow-left me-1"></i>Thoát
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg flex-fill" onclick="return confirm('Xác nhận xuất hủy các mặt hàng này? Phép toán không thể hoàn tác!')">
                                <i class="fas fa-trash-alt me-2"></i>Xác nhận Hủy
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var rowIndex = 1;
    var optionsHtml = $('#tbodyXuatHang tr:first select').html();

    initSelect2Row($('#tbodyXuatHang tr:first select'));

    $('#btnThemDong').on('click', function() {
        addNewRow();
    });

    function addNewRow(selectedMaSP) {
        var html = `<tr class="xuat-row" data-index="${rowIndex}">
            <td>
                <select name="DanhSachXuat[${rowIndex}].MaSP" class="form-select select2-row" required>
                    ${optionsHtml}
                </select>
            </td>
            <td><input name="DanhSachXuat[${rowIndex}].SoLuong" type="number" step="0.01" min="0.01" class="form-control txt-soluong" required /></td>
            <td>
                <div class="input-group input-group-sm mb-1">
                    <input name="DanhSachXuat[${rowIndex}].DonViQuyDoi" class="form-control" placeholder="ĐVT..." />
                    <span class="input-group-text bg-light">x</span>
                    <input name="DanhSachXuat[${rowIndex}].HeSoQuyDoi" type="number" step="0.01" min="1" class="form-control txt-heso" value="1" />
                </div>
                <small class="text-muted" style="font-size:0.7rem;">Gốc: <span class="badge bg-info lbl-dvt">---</span></small>
            </td>
            <td><strong class="text-success lbl-tonkho">---</strong></td>
            <td><strong class="text-danger lbl-thanhtien">---</strong></td>
            <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger btn-xoa-dong" title="Xóa dòng"><i class="fas fa-trash"></i></button></td>
        </tr>`;
        
        $('#tbodyXuatHang').append(html);
        var newSelect = $(`#tbodyXuatHang tr[data-index="${rowIndex}"] select`);
        initSelect2Row(newSelect);
        
        if (selectedMaSP) {
            newSelect.val(selectedMaSP).trigger('change');
        }
        rowIndex++;
    }

    function initSelect2Row(el) {
        el.select2({
            theme: 'bootstrap-5',
            placeholder: 'Gõ tên sản phẩm để tìm...',
            allowClear: true,
            width: '100%'
        });
    }

    $(document).on('click', '.btn-xoa-dong', function() {
        if ($('#tbodyXuatHang tr').length <= 1) {
            alert('Phải giữ ít nhất 1 dòng!');
            return;
        }
        $(this).closest('tr').remove();
    });

    $(document).on('change', '.select2-row', function() {
        var row = $(this).closest('tr');
        var maSP = $(this).val();
        
        if(!maSP) {
            resetRow(row);
            return;
        }

        $.get('/XuatKho/GetTonKho', { maSP: maSP }, function(data) {
             if (data.success) {
                 row.find('.lbl-dvt').text(data.donViTinh);
                 row.find('.lbl-tonkho').text(data.tonKho.toLocaleString('en-US') + ' ' + data.donViTinh);
                 row.data('giaban', data.giaBan);
                 
                 var inputSL = row.find('.txt-soluong');
                 if (data.donViTinh === 'Kg') {
                     inputSL.attr('step', '0.01').attr('min', '0.01');
                 } else {
                     inputSL.attr('step', '1').attr('min', '1');
                     var val = parseFloat(inputSL.val());
                     if (val && val % 1 !== 0) inputSL.val(Math.floor(val));
                 }
                 
                 inputSL.attr('max', data.tonKho);
                 calcTotalRow(row);
             } else {
                 resetRow(row);
             }
        });
    });

    $(document).on('input', '.txt-soluong, .txt-heso', function() {
        var row = $(this).closest('tr');
        var sl = parseFloat(row.find('.txt-soluong').val()) || 0;
        var heso = parseFloat(row.find('.txt-heso').val()) || 1;
        var tongSlGoc = sl * heso;
        var max = parseFloat(row.find('.txt-soluong').attr('max')) || 0; 
        
        if(tongSlGoc > max && max > 0) {
            alert('Lỗi: Tổng số lượng xuất sau quy đổi (' + tongSlGoc + ') vượt quá tồn kho an toàn (' + max + ')!');
            row.find('.txt-soluong').val(1);
            row.find('.txt-heso').val(1);
        }
        calcTotalRow(row);
    });

    function resetRow(row) {
        row.find('.lbl-dvt').text('---');
        row.find('.lbl-tonkho').text('---');
        row.find('.lbl-thanhtien').text('---');
        row.data('giaban', 0);
        row.find('.txt-soluong').removeAttr('max');
    }

    function calcTotalRow(row) {
        var sl = parseFloat(row.find('.txt-soluong').val()) || 0;
        var heso = parseFloat(row.find('.txt-heso').val()) || 1;
        var gia = parseFloat(row.data('giaban')) || 0;
        var tt = sl * heso * gia;
        row.find('.lbl-thanhtien').text(tt > 0 ? tt.toLocaleString('vi-VN') + 'đ' : '---');
    }

    $('#formHuyHang').on('submit', function(e) {
        var valid = true;
        var errMSG = "";
        
        $('#tbodyXuatHang tr').each(function() {
            var input = $(this).find('.txt-soluong');
            var dvt = $(this).find('.lbl-dvt').text();
            var sl = parseFloat(input.val()) || 0;
            var tonkho = parseFloat(input.attr('max')) || 0;
            var maSP = $(this).find('.select2-row').val();
            
            if(!maSP) {
                valid = false; errMSG = "Vui lòng chọn sản phẩm."; return false;
            }
            if (sl <= 0) {
                valid = false; errMSG = "Số lượng phải > 0."; return false;
            }
            if(dvt !== 'Kg' && sl % 1 !== 0) {
                valid = false; errMSG = "Hàng đóng gói (hộp/khay) không được nhập số thập phân."; return false;
            }
            if(sl > tonkho) {
                valid = false; errMSG = "Sản phẩm đang vượt tồn kho cho phép."; return false;
            }
        });

        if (!valid) {
            e.preventDefault();
            alert(errMSG);
        }
    });
</script>
}
