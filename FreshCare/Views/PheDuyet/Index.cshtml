@model List<FreshCare.Models.YeuCauPheDuyet>
@{ ViewData["Title"] = "Phê duyệt yêu cầu"; }

<h4 class="section-title"><i class="fas fa-clipboard-check me-2"></i>Phê Duyệt Yêu Cầu Chỉnh Sửa</h4>

@{ var choDuyet = Model.Where(x => x.TrangThai == "Chờ Duyệt").ToList(); }
@{ var daDuyet = Model.Where(x => x.TrangThai != "Chờ Duyệt").ToList(); }

@if (choDuyet.Any())
{
    <div class="card card-fc border-start border-warning border-4 mb-4">
        <div class="card-header" style="background: linear-gradient(135deg, #f4a261, #e76f51); color: #fff;">
            <h5 class="mb-0"><i class="fas fa-hourglass-half me-2"></i>Đang chờ duyệt (@choDuyet.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-fc table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th><th>Nhân viên</th><th>Phân hệ</th><th>Loại</th>
                            <th>Mã bản ghi</th><th>Dữ liệu mới</th><th>Ngày gửi</th><th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var yc in choDuyet)
                        {
                            <tr class="table-warning">
                                <td><strong>#@yc.MaYeuCau</strong></td>
                                <td>@yc.TenNhanVienGhi</td>
                                <td><span class="badge bg-info">@yc.PhanHe</span></td>
                                <td><span class="badge bg-warning text-dark">@yc.LoaiChinhSua</span></td>
                                <td>@yc.MaBanGhi</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#modal_@yc.MaYeuCau">
                                        <i class="fas fa-eye me-1"></i>Xem
                                    </button>
                                </td>
                                <td><small>@yc.NgayGui.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td>
                                    <form asp-action="Duyet" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="maYeuCau" value="@yc.MaYeuCau" />
                                        <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Xác nhận DUYỆT yêu cầu #@yc.MaYeuCau?')">
                                            <i class="fas fa-check me-1"></i>Duyệt
                                        </button>
                                    </form>
                                    <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#reject_@yc.MaYeuCau">
                                        <i class="fas fa-times me-1"></i>Từ chối
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modals xem chi tiết & từ chối -->
    @foreach (var yc in choDuyet)
    {
        <!-- Modal xem dữ liệu -->
        <div class="modal fade" id="modal_@yc.MaYeuCau" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content" style="border-radius:16px;">
                    <div class="modal-header bg-info text-white" style="border-radius:16px 16px 0 0;">
                        <h5 class="modal-title">Chi tiết yêu cầu #@yc.MaYeuCau</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p><strong>Nhân viên:</strong> @yc.TenNhanVienGhi</p>
                        <p><strong>Phân hệ:</strong> @yc.PhanHe — <strong>Loại:</strong> @yc.LoaiChinhSua</p>
                        <p><strong>Mã bản ghi:</strong> #@yc.MaBanGhi</p>
                        <hr />
                        <p><strong>Dữ liệu mới:</strong></p>
                        <pre class="bg-light p-3 rounded" style="white-space:pre-wrap;font-size:0.85rem;">@yc.DuLieuMoi</pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal từ chối -->
        <div class="modal fade" id="reject_@yc.MaYeuCau" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content" style="border-radius:16px;">
                    <div class="modal-header bg-danger text-white" style="border-radius:16px 16px 0 0;">
                        <h5 class="modal-title">Từ chối yêu cầu #@yc.MaYeuCau</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="TuChoi" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="maYeuCau" value="@yc.MaYeuCau" />
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Lý do từ chối</label>
                                <textarea name="ghiChu" class="form-control" rows="3" placeholder="Nhập lý do..."></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-danger"><i class="fas fa-times me-1"></i>Xác nhận từ chối</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>Không có yêu cầu nào đang chờ duyệt.</div>
}

<!-- Lịch sử đã xử lý -->
@if (daDuyet.Any())
{
    <div class="card card-fc mt-3">
        <div class="card-header" style="background: var(--fc-primary); color: #fff;">
            <h5 class="mb-0"><i class="fas fa-check-double me-2"></i>Đã xử lý (@daDuyet.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-fc table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th><th>Nhân viên</th><th>Phân hệ</th><th>Loại</th>
                            <th>Trạng thái</th><th>Người duyệt</th><th>Ngày duyệt</th><th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var yc in daDuyet)
                        {
                            string rowClass = yc.TrangThai == "Đã Duyệt" ? "table-success" : "table-danger";
                            <tr class="@rowClass">
                                <td>#@yc.MaYeuCau</td>
                                <td>@yc.TenNhanVienGhi</td>
                                <td>@yc.PhanHe</td>
                                <td>@yc.LoaiChinhSua</td>
                                <td>
                                    @if (yc.TrangThai == "Đã Duyệt")
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i>Đã Duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Từ Chối</span>
                                    }
                                </td>
                                <td>@(yc.TenNguoiDuyet ?? "—")</td>
                                <td><small>@(yc.NgayDuyet?.ToString("dd/MM/yyyy HH:mm") ?? "—")</small></td>
                                <td><small>@(yc.GhiChu ?? "—")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
