@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard - Cảnh báo Hạn sử dụng"; }

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card bg-fc-info">
            <h3>@Model.TongSanPham</h3>
            <p>Tổng sản phẩm</p>
            <i class="fas fa-box stat-icon"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-fc-success">
            <h3>@Model.TongLoHang</h3>
            <p>Tổng lô hàng</p>
            <i class="fas fa-cubes stat-icon"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-fc-warning">
            <h3>@Model.SoLoCanDate</h3>
            <p>Lô cận date</p>
            <i class="fas fa-clock stat-icon"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-fc-danger">
            <h3>@Model.SoLoQuaHan</h3>
            <p>Lô quá hạn</p>
            <i class="fas fa-exclamation-triangle stat-icon"></i>
        </div>
    </div>
</div>

<!-- NAV TABS -->
<ul class="nav nav-pills mb-4 gap-2" id="dashboardTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold text-danger border border-danger bg-white" id="quahan-tab" data-bs-toggle="tab" data-bs-target="#quahan" type="button" role="tab" style="min-width: 200px;">
            <i class="fas fa-skull-crossbones me-2"></i>QUÁ HẠN <span class="badge bg-danger ms-1">@Model.SoLoQuaHan</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-warning border border-warning bg-white" id="candate-tab" data-bs-toggle="tab" data-bs-target="#candate" type="button" role="tab" style="min-width: 200px;">
            <i class="fas fa-exclamation-circle me-2"></i>CẬN DATE <span class="badge bg-warning text-dark ms-1">@Model.SoLoCanDate</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-success border border-success bg-white" id="antoan-tab" data-bs-toggle="tab" data-bs-target="#antoan" type="button" role="tab" style="min-width: 200px;">
            <i class="fas fa-check-circle me-2"></i>AN TOÀN <span class="badge bg-success ms-1">@Model.LoHangAnToan.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-secondary border border-secondary bg-white" id="bancham-tab" data-bs-toggle="tab" data-bs-target="#bancham" type="button" role="tab" style="min-width: 200px;">
            <i class="fas fa-hourglass-half me-2"></i>BÁN CHẬM <span class="badge bg-secondary ms-1">@Model.SanPhamBanCham.Count</span>
        </button>
    </li>
</ul>

<style>
    /* Styling for active tabs */
    #dashboardTabs .nav-link.active#quahan-tab { background: var(--fc-danger) !important; color: white !important; }
    #dashboardTabs .nav-link.active#candate-tab { background: var(--fc-warning) !important; color: #333 !important; }
    #dashboardTabs .nav-link.active#antoan-tab { background: var(--fc-success) !important; color: white !important; }
    #dashboardTabs .nav-link.active#bancham-tab { background: #6c757d !important; color: white !important; }
    #dashboardTabs .nav-link.active .badge { background: white !important; color: #333 !important; }
    
    .pagination-container { margin-top: 1rem; display: flex; justify-content: center; }
    .pagination .page-item .page-link { color: var(--fc-primary); cursor: pointer; border-radius: 4px; margin: 0 2px;}
    .pagination .page-item.active .page-link { background-color: var(--fc-primary); border-color: var(--fc-primary); color: white;}
</style>

<!-- TABS CONTENT -->
<div class="tab-content" id="dashboardTabsContent">
    
    <!-- TAB: QUÁ HẠN -->
    <div class="tab-pane fade show active" id="quahan" role="tabpanel">
        <div class="card card-fc border-start border-danger border-4">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">LÔ HÀNG QUÁ HẠN — Cần xuất hủy ngay!</h5>
                <button type="submit" form="frmHuyHangLoat" class="btn btn-sm btn-light text-danger fw-bold shadow-sm" onclick="return confirm('Xác nhận xuất hủy các lô hàng đã chọn?')">
                    <i class="fas fa-trash-alt me-1"></i>Hủy các mục đã chọn
                </button>
            </div>
            <div class="card-body p-0">
                <form id="frmHuyHangLoat" asp-controller="XuatKho" asp-action="HuyHangLoat" method="post">
                @Html.AntiForgeryToken()
                <div class="table-responsive">
                    <table class="table table-fc table-hover mb-0" id="tblQuaHan">
                        <thead>
                            <tr>
                                <th><input type="checkbox" class="form-check-input" id="chkAllQuaHan" onclick="toggleCheckAll(this, 'maLoList')" /></th>
                                <th>Mã Lô</th><th>Sản phẩm</th><th>Danh mục</th><th>Đơn vị</th><th>Tồn kho</th>
                                <th>NSX</th><th>HSD</th><th>Ngày nhập kho</th><th>Ngày còn lại</th><th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.LoHangQuaHan.Any())
                            {
                                <tr><td colspan="11" class="text-center text-muted py-4">Không có lô hàng quá hạn</td></tr>
                            }
                            @foreach (var lo in Model.LoHangQuaHan)
                            {
                                <tr class="table-danger paginate-row">
                                    <td><input type="checkbox" class="form-check-input chk-item" name="maLoList" value="@lo.MaLo" /></td>
                                    <td><strong>LO-@lo.MaLo.ToString("D4")</strong></td>
                                    <td>@lo.TenSP</td>
                                    <td><span class="badge bg-light text-dark border">@lo.TenDanhMuc</span></td>
                                    <td>@lo.DonViTinh</td>
                                    <td><strong>@lo.SoLuongTon.ToString("N2")</strong></td>
                                    <td>@lo.NgaySanXuat.ToString("dd/MM/yyyy")</td>
                                    <td>@lo.HanSuDung.ToString("dd/MM/yyyy")</td>
                                    <td>@lo.NgayNhapKho.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge bg-danger">@lo.SoNgayConLai ngày</span></td>
                                    <td>
                                        <form asp-controller="XuatKho" asp-action="HuyHang" method="post" class="d-inline"
                                              onsubmit="return confirm('Xác nhận xuất hủy lô LO-@lo.MaLo.ToString("D4")?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maLo" value="@lo.MaLo" />
                                            <button type="submit" class="btn btn-sm btn-fc-danger">
                                                <i class="fas fa-trash-alt me-1"></i>Xuất Hủy
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                </form>
                <div class="pagination-container" id="pagQuaHan"></div>
            </div>
        </div>
    </div>

    <!-- TAB: CẬN DATE -->
    <div class="tab-pane fade" id="candate" role="tabpanel">
        <div class="card card-fc border-start border-warning border-4">
            <div class="card-header" style="background: linear-gradient(135deg, #f4a261, #e76f51); color: #fff;">
                <h5 class="mb-0">LÔ HÀNG CẬN DATE (&lt; 14 ngày) — Gợi ý giảm giá!</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-fc table-hover mb-0" id="tblCanDate">
                        <thead>
                            <tr>
                                <th>Mã Lô</th><th>Sản phẩm</th><th>Danh mục</th><th>Đơn vị</th><th>Tồn kho</th>
                                <th>HSD</th><th>Ngày nhập kho</th><th>Ngày còn lại</th><th>Giá gốc</th><th>Giá Sale</th><th>Giảm</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.LoHangCanDate.Any())
                            {
                                <tr><td colspan="12" class="text-center text-muted py-4">Không có lô hàng cận date</td></tr>
                            }
                            @foreach (var lo in Model.LoHangCanDate)
                            {
                                <tr class="table-warning paginate-row">
                                    <td><strong>LO-@lo.MaLo.ToString("D4")</strong></td>
                                    <td>@lo.TenSP</td>
                                    <td><span class="badge bg-light text-dark border">@lo.TenDanhMuc</span></td>
                                    <td>@lo.DonViTinh</td>
                                    <td><strong>@lo.SoLuongTon.ToString("N2")</strong></td>
                                    <td>@lo.HanSuDung.ToString("dd/MM/yyyy")</td>
                                    <td>@lo.NgayNhapKho.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge badge-can-date">@lo.SoNgayConLai ngày</span></td>
                                    <td><span class="gia-goc">@lo.GiaBanGoc.ToString("N0")đ</span></td>
                                    <td><span class="gia-sale">@lo.GiaThucTe.ToString("N0")đ</span></td>
                                    <td><span class="badge bg-danger">-@lo.PhanTramSaleHienTai%</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="pagination-container" id="pagCanDate"></div>
            </div>
        </div>
    </div>

    <!-- TAB: AN TOÀN -->
    <div class="tab-pane fade" id="antoan" role="tabpanel">
        <div class="card card-fc border-start border-success border-4">
            <div class="card-header" style="background: linear-gradient(135deg, #2a9d8f, #2d6a4f); color: #fff;">
                <h5 class="mb-0">LÔ HÀNG AN TOÀN (@Model.LoHangAnToan.Count lô)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-fc table-hover mb-0" id="tblAnToan">
                        <thead>
                            <tr>
                                <th>Mã Lô</th><th>Sản phẩm</th><th>Danh mục</th><th>Đơn vị</th>
                                <th>Tồn kho</th><th>NSX</th><th>HSD</th><th>Ngày nhập kho</th><th>Ngày còn lại</th><th>Giá bán</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.LoHangAnToan.Any())
                            {
                                <tr><td colspan="11" class="text-center text-muted py-4">Không có lô hàng an toàn trong kho</td></tr>
                            }
                            @foreach (var lo in Model.LoHangAnToan)
                            {
                                <tr class="paginate-row">
                                    <td><strong>LO-@lo.MaLo.ToString("D4")</strong></td>
                                    <td>@lo.TenSP</td>
                                    <td><span class="badge bg-light text-dark">@lo.TenDanhMuc</span></td>
                                    <td>@lo.DonViTinh</td>
                                    <td><strong>@lo.SoLuongTon.ToString("N2")</strong></td>
                                    <td>@lo.NgaySanXuat.ToString("dd/MM/yyyy")</td>
                                    <td>@lo.HanSuDung.ToString("dd/MM/yyyy")</td>
                                    <td>@lo.NgayNhapKho.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge badge-an-toan">@lo.SoNgayConLai ngày</span></td>
                                    <td>@lo.GiaBanGoc.ToString("N0")đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="pagination-container" id="pagAnToan"></div>
            </div>
        </div>
    </div>

    <!-- TAB: BÁN CHẬM -->
    <div class="tab-pane fade" id="bancham" role="tabpanel">
        <div class="card card-fc border-start border-secondary border-4">
            <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>SẢN PHẨM BÁN CHẬM (Tồn nhiều - Ít xuất)</h5>
                @if (Context.Session.GetString("VaiTro") == "Admin")
                {
                    <button type="button" class="btn btn-sm btn-light text-dark shadow-sm" data-bs-toggle="modal" data-bs-target="#modalCauHinhBanCham">
                        <i class="fas fa-cog me-1"></i> Cấu hình Thuật toán
                    </button>
                }
            </div>
            <div class="card-body p-0">
                <div class="px-3 pt-3 pb-1 bg-light border-bottom">
                    <p class="text-muted small mb-0"><i class="fas fa-info-circle me-1"></i>Thuật toán hiện tại: Gợi ý các mặt hàng <strong>hiện đang còn tồn kho</strong> nhưng tổng số lượng bán ra trong <strong class="text-primary">@Model.SoNgayBanCham ngày qua</strong> chỉ đạt <strong class="text-danger">&lt;= @Model.SoLuongBanChamThreshold</strong> sản phẩm/đơn vị.</p>
                </div>
                <div class="table-responsive">
                    <table class="table table-fc table-hover mb-0" id="tblBanCham">
                        <thead>
                            <tr>
                                <th style="width:10%;">Mã SP</th>
                                <th>Tên Sản phẩm</th>
                                <th style="width:15%;">Đơn vị tính</th>
                                <th style="width:25%;">Đã bán (@Model.SoNgayBanCham ngày qua)</th>
                                <th style="width:15%;">Đánh giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.SanPhamBanCham.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">Tất cả sản phẩm đang kinh doanh tốt!</td></tr>
                            }
                            @foreach (var sp in Model.SanPhamBanCham)
                            {
                                <tr class="paginate-row">
                                    <td><strong>SP-@sp.MaSP.ToString("D4")</strong></td>
                                    <td>@sp.TenSP</td>
                                    <td>@sp.DonViTinh</td>
                                    <td><strong class="text-danger">@sp.TongSoLuong.ToString("N2")</strong></td>
                                    <td><span class="badge bg-secondary">Bán cực chậm</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="pagination-container" id="pagBanCham"></div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cấu hình Bán Chậm -->
<div class="modal fade" id="modalCauHinhBanCham" tabindex="-1">
    <div class="modal-dialog">
        <form asp-controller="Home" asp-action="CapNhatCauHinhBanCham" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"><i class="fas fa-cogs me-2 text-primary"></i>Cấu hình Thuật toán Bán chậm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tính trong khoảng thời gian (Ngày):</label>
                    <input type="number" name="soNgay" class="form-control" value="@Model.SoNgayBanCham" required min="1" step="1" />
                    <small class="text-muted">Khoảng thời gian lùi lại từ ngày hiện tại.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ngưỡng gọi là "Bán chậm" (Số lượng &lt;=):</label>
                    <input type="number" name="soLuong" class="form-control" value="@Model.SoLuongBanChamThreshold" required min="0" step="1" />
                    <small class="text-muted">Các sản phẩm bán được số lượng nhỏ hơn hoặc bằng mức này sẽ bị cảnh báo.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Lưu cấu hình</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Client-side pagination logic
    document.addEventListener("DOMContentLoaded", function () {
        function setupPagination(tableId, containerId, itemsPerPage = 10) {
            const table = document.getElementById(tableId);
            if (!table) return;
            const rows = Array.from(table.querySelectorAll('tbody tr.paginate-row'));
            const container = document.getElementById(containerId);
            if (!rows.length || rows.length <= itemsPerPage) return; // No need to paginate

            const totalPages = Math.ceil(rows.length / itemsPerPage);
            let currentPage = 1;

            function showPage(page) {
                // Hide all
                rows.forEach(r => r.style.display = 'none');
                // Show current slice
                const start = (page - 1) * itemsPerPage;
                const end = start + itemsPerPage;
                rows.slice(start, end).forEach(r => r.style.display = '');

                // Render buttons
                container.innerHTML = '';
                const ul = document.createElement('ul');
                ul.className = 'pagination pagination-sm m-0 pb-3 h-100';

                for (let i = 1; i <= totalPages; i++) {
                    const li = document.createElement('li');
                    li.className = 'page-item' + (i === page ? ' active' : '');
                    const a = document.createElement('a');
                    a.className = 'page-link';
                    a.innerText = i;
                    a.onclick = function (e) {
                        e.preventDefault();
                        currentPage = i;
                        showPage(currentPage);
                    };
                    li.appendChild(a);
                    ul.appendChild(li);
                }
                container.appendChild(ul);
            }
            showPage(1);
        }

        setupPagination('tblQuaHan', 'pagQuaHan', 10);
        setupPagination('tblCanDate', 'pagCanDate', 10);
        setupPagination('tblAnToan', 'pagAnToan', 10);
        setupPagination('tblBanCham', 'pagBanCham', 10);
    });

    // Chọn/bỏ chọn tất cả checkbox theo tên
    function toggleCheckAll(source, name) {
        var checkboxes = document.querySelectorAll('input[name="' + name + '"]');
        checkboxes.forEach(function(cb) { cb.checked = source.checked; });
    }
</script>
