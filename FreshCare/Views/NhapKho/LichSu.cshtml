@model List<PhieuNhapKho>
@{ ViewData["Title"] = "Lịch sử Nhập kho"; }

<h4 class="section-title"><i class="fas fa-file-import me-2"></i>Lịch Sử Phiếu Nhập Kho</h4>

<div class="card card-fc mb-3">
    <div class="card-body">
        <form class="row g-2 align-items-end" method="get" action="/NhapKho/InTongHopNgay">
            <div class="col-auto">
                <label class="form-label fw-semibold small mb-1">Chọn ngày</label>
                <input type="date" name="ngay" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-fc-primary">
                    <i class="fas fa-print me-1"></i>In tổng hợp ngày
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card card-fc">
    <div class="card-body p-0">
        <table class="table table-fc table-hover mb-0">
            <thead><tr><th>Mã Phiếu</th><th>Ngày nhập</th><th>Nhân viên</th><th>Tên mặt hàng</th><th>Ghi chú</th><th>Thao tác</th></tr></thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>PN-@p.MaPhieuNhap.ToString("D4")</strong></td>
                        <td>@p.NgayNhap.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@p.TenNhanVien</td>
                        <td><em>@(p.TenMatHang ?? "—")</em></td>
                        <td>@(p.GhiChu ?? "—")</td>
                        <td>
                            <a href="/NhapKho/ChiTiet?id=@p.MaPhieuNhap" class="btn btn-sm btn-outline-primary" title="Xem chi tiết và In phiếu">
                                <i class="fas fa-print me-1"></i>Xem / In
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Chưa có phiếu nhập nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

