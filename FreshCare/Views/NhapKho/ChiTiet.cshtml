@model FreshCare.Models.ViewModels.ChiTietPhieuNhapViewModel
@{
    ViewData["Title"] = "Chi Tiết Phiếu Nhập: " + Model.MaPhieuNhap;
}

@section Styles {
<style>
    /* Phần CSS riêng cho giao diện in ấn (Print) */
    @@media print {
        body * {
            visibility: hidden;
        }
        #printable-invoice, #printable-invoice * {
            visibility: visible;
        }
        #printable-invoice {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }
        .btn, .navbar-freshcare, .no-print {
            display: none !important;
        }
        .table-fc thead th {
            background-color: #f8f9fa !important;
            color: #000 !important;
            border-bottom: 2px solid #2d6a4f !important;
        }
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    }

    .invoice-card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        padding: 30px;
        background: #fff;
    }
    
    .invoice-header {
        border-bottom: 2px solid #2d6a4f;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }
</style>
}

<div class="row mb-3 no-print">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <a href="/NhapKho/LichSu" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Quay lại
        </a>
        <button onclick="window.print()" class="btn btn-fc-primary">
            <i class="fas fa-print me-1"></i> In Phiếu Nhập
        </button>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="invoice-card" id="printable-invoice">
            <!-- Header Phiếu Nhập -->
            <div class="invoice-header d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-0" style="color: #2d6a4f; font-weight: 700;">
                        <i class="fas fa-leaf me-2"></i> FRESHCARE
                    </h3>
                    <p class="text-muted mb-0 small">Thực phẩm Tươi sạch & Hữu cơ</p>
                </div>
                <div class="text-end">
                    <h5 class="fw-bold mb-1">PHIẾU NHẬP KHO</h5>
                    <p class="mb-0 text-muted">Số phiếu: <strong>PN-@Model.MaPhieuNhap.ToString("D4")</strong></p>
                </div>
            </div>

            <!-- Thông tin phiếu -->
            <div class="row mb-4 pt-2">
                <div class="col-sm-6">
                    <h6 class="fw-bold">Thông tin nhập kho:</h6>
                    <p class="mb-1 small">Chi nhánh: Cơ sở chính</p>
                    <p class="mb-1 small">Nhân viên lập: <strong>@Model.TenNhanVien</strong></p>
                    @if (!string.IsNullOrEmpty(Model.GhiChu))
                    {
                        <p class="mb-1 small">Ghi chú: <em>@Model.GhiChu</em></p>
                    }
                </div>
                <div class="col-sm-6 text-sm-end">
                    <p class="mb-1 small">Thời gian: <strong>@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</strong></p>
                    <p class="mb-1 small">Loại chứng từ: <span class="badge bg-primary">Nhập Kho</span></p>
                </div>
            </div>

            <!-- Chi tiết hàng hóa -->
            <table class="table table-fc table-bordered mb-4">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Sản phẩm</th>
                        <th class="text-center">Đơn vị</th>
                        <th class="text-center">Số lô</th>
                        <th class="text-end">Số lượng</th>
                        <th class="text-end">Giá nhập</th>
                        <th class="text-end">Thành tiền</th>
                        <th class="text-center">NSX</th>
                        <th class="text-center">HSD</th>
                        <th class="text-center">Ngày nhập kho</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model.DanhSachChiTiet)
                    {
                        <tr>
                            <td class="text-center">@(stt++)</td>
                            <td><strong>@item.TenSanPham</strong></td>
                            <td class="text-center"><span class="badge bg-info">@item.DonViTinh</span></td>
                            <td class="text-center">LO-@item.MaLo.ToString("D4")</td>
                            <td class="text-end">@item.SoLuong.ToString("G29")</td>
                            <td class="text-end">@item.GiaNhap.ToString("N0")đ</td>
                            <td class="text-end fw-semibold">@( (item.SoLuong * item.GiaNhap).ToString("N0") )đ</td>
                            <td class="text-center small">@item.NgaySanXuat.ToString("dd/MM/yyyy")</td>
                            <td class="text-center small">@item.HanSuDung.ToString("dd/MM/yyyy")</td>
                            <td class="text-center small">@item.NgayNhapKho.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Tổng kết phiếu nhập -->
            <div class="row">
                <div class="col-7">
                    <p class="small text-muted fst-italic">Phiếu nhập kho — FreshCare Inventory System</p>
                </div>
                <div class="col-5 text-end">
                    <div class="fs-5 fw-bold" style="color: #2d6a4f;">
                        Tổng giá trị nhập: <span>@Model.TongTien.ToString("N0") đ</span>
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top">
                <div class="row text-center small text-muted">
                    <div class="col-4">
                        <p class="mb-0 fw-bold">Người lập phiếu</p>
                        <p class="mt-4">@Model.TenNhanVien</p>
                    </div>
                    <div class="col-4">
                        <p class="mb-0 fw-bold">Thủ kho</p>
                        <p class="mt-4">_______________</p>
                    </div>
                    <div class="col-4">
                        <p class="mb-0 fw-bold">Quản lý</p>
                        <p class="mt-4">_______________</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
