@model FreshCare.Models.ViewModels.TongHopNhapNgayViewModel
@{
    ViewData["Title"] = "Tổng hợp Nhập kho ngày " + Model.Ngay.ToString("dd/MM/yyyy");
}

@section Styles {
<style>
    @@media print {
        body * { visibility: hidden; }
        #printable-invoice, #printable-invoice * { visibility: visible; }
        #printable-invoice { position: absolute; left: 0; top: 0; width: 100%; }
        .btn, .navbar-freshcare, .no-print { display: none !important; }
        .table-fc thead th { background-color: #f8f9fa !important; color: #000 !important; border-bottom: 2px solid #2d6a4f !important; }
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    }
    .invoice-card { border: none; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); padding: 30px; background: #fff; }
    .invoice-header { border-bottom: 2px solid #2d6a4f; padding-bottom: 15px; margin-bottom: 20px; }
</style>
}

<div class="row mb-3 no-print">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <a href="/NhapKho/LichSu" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Quay lại
        </a>
        <button onclick="window.print()" class="btn btn-fc-primary">
            <i class="fas fa-print me-1"></i> In Tổng Hợp
        </button>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="invoice-card" id="printable-invoice">
            <div class="invoice-header d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-0" style="color: #2d6a4f; font-weight: 700;">
                        <i class="fas fa-leaf me-2"></i> FRESHCARE
                    </h3>
                    <p class="text-muted mb-0 small">Thực phẩm Tươi sạch &amp; Hữu cơ</p>
                </div>
                <div class="text-end">
                    <h5 class="fw-bold mb-1">TỔNG HỢP NHẬP KHO</h5>
                    <p class="mb-0 text-muted">Ngày: <strong>@Model.Ngay.ToString("dd/MM/yyyy")</strong></p>
                </div>
            </div>

            @if (!Model.DanhSachPhieu.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-inbox fa-3x mb-3"></i>
                    <p>Không có phiếu nhập nào trong ngày này.</p>
                </div>
            }
            else
            {
                int sttGlobal = 1;
                foreach (var phieu in Model.DanhSachPhieu)
                {
                    <div class="mb-4 pb-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold mb-0">
                                <span class="badge bg-primary me-1">PN-@phieu.MaPhieuNhap.ToString("D4")</span>
                                NV: @phieu.TenNhanVien — @phieu.NgayNhap.ToString("HH:mm")
                            </h6>
                            <span class="fw-semibold" style="color: #2d6a4f;">@phieu.TongTien.ToString("N0") đ</span>
                        </div>
                        @if (!string.IsNullOrEmpty(phieu.GhiChu))
                        {
                            <p class="small text-muted mb-2"><em>Ghi chú: @phieu.GhiChu</em></p>
                        }
                        <table class="table table-fc table-bordered table-sm mb-0">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width:40px;">STT</th>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">ĐVT</th>
                                    <th class="text-end">SL</th>
                                    <th class="text-end">Giá nhập</th>
                                    <th class="text-end">Thành tiền</th>
                                    <th class="text-center">NSX</th>
                                    <th class="text-center">HSD</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in phieu.DanhSachChiTiet)
                                {
                                    <tr>
                                        <td class="text-center">@(sttGlobal++)</td>
                                        <td><strong>@item.TenSanPham</strong></td>
                                        <td class="text-center"><span class="badge bg-info">@item.DonViTinh</span></td>
                                        <td class="text-end">@item.SoLuong.ToString("G29")</td>
                                        <td class="text-end">@item.GiaNhap.ToString("N0")đ</td>
                                        <td class="text-end fw-semibold">@((item.SoLuong * item.GiaNhap).ToString("N0"))đ</td>
                                        <td class="text-center small">@item.NgaySanXuat.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center small">@item.HanSuDung.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="row mt-3">
                    <div class="col-7">
                        <p class="small text-muted fst-italic">Tổng hợp nhập kho — FreshCare Inventory System</p>
                        <p class="small"><strong>Tổng số phiếu:</strong> @Model.DanhSachPhieu.Count</p>
                    </div>
                    <div class="col-5 text-end">
                        <div class="fs-5 fw-bold" style="color: #2d6a4f;">
                            Tổng giá trị nhập: <span>@Model.TongTien.ToString("N0") đ</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <div class="row text-center small text-muted">
                        <div class="col-4">
                            <p class="mb-0 fw-bold">Người lập</p>
                            <p class="mt-4">_______________</p>
                        </div>
                        <div class="col-4">
                            <p class="mb-0 fw-bold">Thủ kho</p>
                            <p class="mt-4">_______________</p>
                        </div>
                        <div class="col-4">
                            <p class="mb-0 fw-bold">Quản lý</p>
                            <p class="mt-4">_______________</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
